include README.md
include LICENSE
include pyproject.toml
recursive-include ms_rag *.py
recursive-exclude * __pycache__
recursive-exclude * *.py[cod]
prune .agents
prune .git
prune .kiro
prune .venv
prune build
prune dist
prune docs
prune docs-deploy
prune SmokeDocs
prune Resume
prune tests
prune ms_rag_output
prune generated
